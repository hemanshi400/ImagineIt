# Copy this file to .env.local and fill in your API keys

# Supabase (for database, authentication, and real-time features)
# Create a project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudinary (for media storage and CDN)
# Create an account at: https://cloudinary.com
# Server-side signed uploads need an API key with the "create" asset permission.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Backend secrets (not exposed to frontend)
# OpenAI API (GPT analysis, gpt-image image generation, Sora video for GIFs)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# Optional: override the Sora model used for animated GIFs (defaults to sora-2)
SORA_MODEL=sora-2
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
