# Copy this file to .env.local and fill in your API keys

# OpenAI API (for Whisper, GPT analysis, DALL-E image generation)
# Get your key at: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=sk-proj-...

# Supabase (for database, authentication, and real-time features)
# Create a project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudinary (for media storage and CDN)
# Create an account at: https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name

# Backend secrets (not exposed to frontend)
OPENAI_API_KEY=sk-proj-...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
